# =============================================================================
# Zync Platform – Environment Variables
#
# HYBRID DEV SETUP:
#   Docker local : Redis + Redpanda (Kafka-compatible)  → chạy: docker compose up -d
#   Cloud free   : MongoDB Atlas M0, Cloudinary, Resend → đăng ký 1 lần, điền bên dưới
#
# Bước thiết lập:
#   1. cp .env.example .env
#   2. Điền MONGODB_URI từ Atlas M0
#   3. Điền CLOUDINARY_* từ Cloudinary dashboard
#   4. Điền SMTP_PASS (Resend API key)
#   5. docker compose -f infra/docker-compose.yml up -d
#   6. npm run dev:server
#
# PRODUCTION: chỉ đổi các giá trị đánh dấu [PROD]
# =============================================================================

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────────
# MongoDB – Atlas M0 (cloud free tier)
# Đăng ký: https://cloud.mongodb.com → tạo cluster M0 (free)
# Lấy URI: Connect → Drivers → copy connection string
# ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zyncdb?retryWrites=true&w=majority
# [PROD] MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zyncdb?retryWrites=true&w=majority&tls=true

# ──────────────────────────────────────────────
# Redis – Docker local (~5MB RAM)
# Chạy: docker compose -f infra/docker-compose.yml up -d redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# [PROD] REDIS_URL=rediss://default:<password>@<host>.upstash.io:6380

# ──────────────────────────────────────────────
# Kafka – Redpanda Docker local (~150MB RAM, Kafka-compatible)
# Chạy: docker compose -f infra/docker-compose.yml up -d redpanda
# UI: http://localhost:8080
# ──────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=zync-server
KAFKA_ENABLED=true
# [PROD] KAFKA_BROKERS=<endpoint>.upstash.io:9092
# [PROD] KAFKA_SASL_USERNAME=<upstash-username>
# [PROD] KAFKA_SASL_PASSWORD=<upstash-password>

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=local-dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ──────────────────────────────────────────────
# OTP
# Dev: OTP cố định 123456, không gửi email/SMS thật
# [PROD] OTP_HARDCODE=false + cấu hình SMTP bên dưới
# ──────────────────────────────────────────────
OTP_HARDCODE=true
OTP_HARDCODE_VALUE=123456
OTP_RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_WINDOW_SECONDS=3600

# ──────────────────────────────────────────────
# Email OTP
# Dev khuyen nghi dung Gmail SMTP de test nhanh.
# Tao App Password: Google Account -> Security -> 2-Step Verification -> App passwords.
# ──────────────────────────────────────────────
OTP_EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Zync <your_gmail@gmail.com>"

# Optional: bat Resend API khi can
# OTP_EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM="Zync <onboarding@resend.dev>"

# ──────────────────────────────────────────────
# SMS – Twilio (production only)
# Dev: không cần, OTP_HARDCODE=true đã xử lý
# [PROD] Uncomment và điền giá trị thật từ twilio.com/console
# ──────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────────
# Object Storage – Cloudinary (cloud free: 25 credits/tháng, CDN + image transformation)
# Đăng ký: https://cloudinary.com → Console → Settings → Access Keys
# Cloud name + API Key + API Secret lấy từ Cloudinary dashboard
# Upload flow: server tạo signature → client upload thẳng lên Cloudinary CDN (không qua server)
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
CLOUDINARY_UPLOAD_PRESET=zync-media
# [PROD] Giữ nguyên Cloudinary hoặc upgrade plan nếu cần dung lượng lớn hơn

# ──────────────────────────────────────────────
# Firebase Cloud Messaging – Push Notification (free mãi)
# Dev: không cần – notification worker sẽ log-only nếu thiếu credentials
# [PROD] Tải service account JSON từ Firebase Console
# Option 1: Path to service account JSON file
# Option 2: Inline JSON (for containerized environments)
# ──────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FCM_SERVICE_ACCOUNT_JSON=

# ──────────────────────────────────────────────
# Web Push (VAPID keys) – Browser push notification
# Dev: không cần – Web Push sẽ bị bỏ qua nếu thiếu VAPID keys
# Sinh cặp key: npx web-push generate-vapid-keys
# ──────────────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@zync.io

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8081
# [PROD] CORS_ORIGINS=https://app.zync.io

# ──────────────────────────────────────────────
# Web (Next.js)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
# [PROD] NEXT_PUBLIC_API_URL=https://api.zync.io
# [PROD] NEXT_PUBLIC_WS_URL=wss://api.zync.io

# ──────────────────────────────────────────────
# WebRTC Call / TURN (Milestone A)
# Local: coturn trong docker-compose (port 3478)
# PROD: bat buoc turns:// + TLS certificate hop le
# ──────────────────────────────────────────────
TURN_REALM=zync.local
TURN_USERNAME=zync
TURN_PASSWORD=change_me_turn_password
TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
# [PROD] TURN_URLS=turns:turn1.your-domain.com:5349?transport=tcp,turns:turn2.your-domain.com:5349?transport=tcp

# Bien cho Web client (bat buoc prefix NEXT_PUBLIC de browser doc duoc)
NEXT_PUBLIC_TURN_USERNAME=zync
NEXT_PUBLIC_TURN_PASSWORD=change_me_turn_password
NEXT_PUBLIC_TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
# [PROD] NEXT_PUBLIC_TURN_URLS=turns:turn1.your-domain.com:5349?transport=tcp,turns:turn2.your-domain.com:5349?transport=tcp

# Ephemeral call token (fallback dung JWT_SECRET neu de trong)
CALL_EPHEMERAL_TOKEN_SECRET=change_me_call_token_secret
CALL_EPHEMERAL_TOKEN_TTL_SECONDS=120
CALL_RING_TIMEOUT_MS=30000
# Tu dong dong session connected bi kẹt khi invite moi (ms)
CALL_CONNECTED_STALE_MS=180000

# Web Push client – cùng giá trị với VAPID_PUBLIC_KEY ở server
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=


# ──────────────────────────────────────────────
# Google OAuth (Web client ID từ Google Cloud Console)
#  Đăng ký: https://console.cloud.google.com/apis/credentials → Create Credentials → OAuth 2.0 Client IDs → Web application
#  Authorized JavaScript origins: http://localhost:3001 (dev), https://app.zync.io (prod)
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ──────────────────────────────────────────────
# AI – Google Gemini (Phase AI-0)
# Đăng ký key: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens/ngày (đủ cho dev hoàn toàn)
# ──────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key
AI_MODEL_PRIMARY=gemini-2.5-pro
AI_MODEL_FALLBACK=gemini-2.5-flash
AI_EMBEDDING_MODEL=text-embedding-004
AI_RATE_LIMIT_PER_MINUTE=10
AI_MODERATION_ENABLED=true
AI_ASSISTANT_ENABLED=true
AI_SEARCH_ENABLED=true

# ──────────────────────────────────────────────
# Neon PostgreSQL + pgvector (Phase AI-0)
# Đăng ký: https://neon.tech → Create Project → copy connection string
# Free tier: 0.5 GB storage, 190h compute/tháng – đủ toàn bộ dev ($0)
# Note: Server vẫn chạy bình thường nếu NEON_DATABASE_URL chưa được set
#       (chỉ AI vector features bị disabled, warn sẽ xuất hiện trong log)
# ──────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require

    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.1.0",
    "gcp-metadata": "^5.3.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.2",
    "pgvector": "^0.2.1",
    "prom-client": "^15.1.2",
    "rate-limit-redis": "^4.2.0",
    "resend": "^4.8.0",
    "socket.io": "^4.7.5",
    "twilio": "^5.1.0",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",

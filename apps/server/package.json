{
  "name": "@zync/server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:lan": "node scripts/dev-lan.js",
    "seed:friends:test": "ts-node-dev --transpile-only scripts/seed-friend-test-data.ts",
    "seed:qa": "ts-node-dev --transpile-only scripts/seed-friend-test-data.ts",
    "seed:stickers": "ts-node-dev --transpile-only scripts/seed-stickers.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "seed:users:4": "ts-node-dev --transpile-only scripts/seed.ts",
    "reset:data": "ts-node-dev --transpile-only scripts/reset-data.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^0.10.4",
    "@socket.io/redis-adapter": "^8.3.0",
